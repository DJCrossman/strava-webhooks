# =============================================================================
# Strava Webhook Dashboard — environment configuration
# Copy this file to `.env` and fill in the values.
# =============================================================================

# Secret used to (a) sign/encrypt the Auth.js session and (b) encrypt the
# Strava credential cookie. Generate one with:  openssl rand -base64 32
# This is the ONLY required variable.
AUTH_SECRET=

# Set explicitly when serving over plain HTTP (e.g. local Docker) so Auth.js
# uses non-secure cookies. Usually not required on HTTPS hosts like Vercel.
# AUTH_URL=http://localhost:3000

# --- Strava credentials are entered in the UI -------------------------------
# Users sign in by entering their Strava app's Client ID + Secret on the site;
# nothing Strava-related is needed here. Just set that app's
# "Authorization Callback Domain" (https://www.strava.com/settings/api) to your
# deployment domain (e.g. `localhost` for local dev, `your-app.vercel.app` in prod).
#
# Optional: pre-seed a default login app instead of entering it in the UI:
# AUTH_STRAVA_ID=
# AUTH_STRAVA_SECRET=
